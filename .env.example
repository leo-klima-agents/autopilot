# --- Required (pre-provisioned locally; set as GitHub Actions repository secrets for CI) ---

# Base mainnet JSON-RPC endpoint. Used by: fork tests, indexer, keeper, deploy scripts.
# May point at ANY provider — never assume it is an Alchemy endpoint.
BASE_RPC_URL=

# Alchemy API key for enhanced APIs (token metadata, log queries).
# Alchemy URLs are constructed explicitly from this key — never derived from BASE_RPC_URL.
ALCHEMY_API_KEY=

# --- Optional ---

# Convenience path for Basescan source display only. Nothing in CI or the
# runbooks requires it; verification is keyless via Sourcify (OPERATIONS.md §6).
ETHERSCAN_API_KEY=

# Keeper hot key (keeper host only — never in CI, never in the repo).
# KEEPER_PRIVATE_KEY=
